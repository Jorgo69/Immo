# ============================================================
# IMMO BENIN - ENV CONFIGURATION EXAMPLE
# ============================================================

APP_NAME="Immo Benin"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:3000

# Server
PORT=3000

# Database
DB_CONNECTION=postgres
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=back_end_api_immo_app
DB_USERNAME=root
DB_PASSWORD=root
DB_SYNCHRONIZE=true
DB_LOGGING=true

# Security
JWT_SECRET=
JWT_EXPIRE_IN=7d
ENCRYPTION_KEY=

# Auth
AUTH_CHANNELS="email,whatsapp"
OTP_TTL_MINUTES=10

# Mail (SMTP)
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@immo-benin.local"
MAIL_FROM_NAME="${APP_NAME}"

# Notifications (Web-Push)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# External APIs (FedaPay, Kkiapay)
FEDAPAY_SECRET_KEY=
FEDAPAY_PUBLIC_KEY=
FEDAPAY_MODE=sandbox

KKIAPAY_PUBLIC_KEY=
KKIAPAY_PRIVATE_KEY=
KKIAPAY_SECRET_KEY=
KKIAPAY_MODE=sandbox

# Microservices
SEMANTIC_URL=
